{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "am-i-fundable-design-tokens",
  "name": "Am I Fundable Design Tokens",
  "version": "1.0.0",
  "visibility": "public_runtime_browser_safe",
  "description": "Public-safe design tokens for the Funding Readiness Scorecard static pages and embed surfaces.",
  "principles": [
    "Static-first styling with no framework dependency.",
    "High-contrast, readable UI for funding-readiness guidance.",
    "Embed styles must be scoped so partner sites are not polluted.",
    "No tokens contain provider data, private URLs, credentials, or borrower information."
  ],
  "colors": {
    "ink": {
      "950": {
        "value": "#07111f",
        "usage": "Primary background"
      },
      "900": {
        "value": "#0a1728",
        "usage": "Section background"
      },
      "800": {
        "value": "#0f2236",
        "usage": "Panels and gradients"
      },
      "700": {
        "value": "#14324e",
        "usage": "Secondary deep surface"
      }
    },
    "surface": {
      "base": {
        "value": "#ffffff",
        "usage": "Cards and forms"
      },
      "soft": {
        "value": "#f6f8fb",
        "usage": "Soft card background"
      },
      "muted": {
        "value": "#e8eef6",
        "usage": "Progress tracks and dividers"
      }
    },
    "text": {
      "light": {
        "value": "#f8fbff",
        "usage": "Text on dark backgrounds"
      },
      "dark": {
        "value": "#142033",
        "usage": "Text on light cards"
      },
      "mutedLight": {
        "value": "#a7b7c8",
        "usage": "Muted text on dark backgrounds"
      },
      "mutedDark": {
        "value": "#526174",
        "usage": "Muted text on light backgrounds"
      }
    },
    "accent": {
      "gold": {
        "value": "#d4a64e",
        "usage": "Primary CTA and brand accent"
      },
      "goldLight": {
        "value": "#f0c96d",
        "usage": "Highlight accent"
      },
      "green": {
        "value": "#2ed47a",
        "usage": "Positive readiness signal"
      },
      "lime": {
        "value": "#a6e75c",
        "usage": "Mid/high readiness signal"
      },
      "yellow": {
        "value": "#ffd166",
        "usage": "Review/prep signal"
      },
      "red": {
        "value": "#ff6b6b",
        "usage": "Blocker/warning signal"
      }
    }
  },
  "typography": {
    "fontFamilies": {
      "sans": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "display": "Georgia, \"Times New Roman\", serif"
    },
    "scale": {
      "eyebrow": "0.76rem",
      "body": "1.05rem",
      "lede": "clamp(1.05rem, 2vw, 1.28rem)",
      "h1": "clamp(3rem, 8vw, 6.75rem)",
      "h2": "clamp(2.25rem, 5vw, 4.75rem)",
      "h3": "clamp(1.35rem, 3vw, 2rem)"
    }
  },
  "spacing": {
    "pageX": "clamp(20px, 6vw, 88px)",
    "sectionY": "clamp(64px, 8vw, 116px)",
    "card": "clamp(24px, 4vw, 34px)",
    "gridGap": "18px"
  },
  "radii": {
    "sm": "14px",
    "md": "20px",
    "lg": "30px",
    "pill": "999px"
  },
  "shadows": {
    "soft": "0 20px 54px rgba(0, 0, 0, 0.24)",
    "card": "0 28px 90px rgba(0, 0, 0, 0.35)",
    "form": "0 34px 110px rgba(0, 0, 0, 0.42)"
  },
  "breakpoints": {
    "mobile": "560px",
    "tablet": "760px",
    "desktop": "900px"
  },
  "resultSignals": {
    "highlyFundable": {
      "range": "80-100",
      "color": "green",
      "copyRule": "Use readiness language; do not describe this as an approval."
    },
    "fundableReview": {
      "range": "65-79",
      "color": "lime",
      "copyRule": "Recommend human review before next action."
    },
    "selectiveFit": {
      "range": "45-64",
      "color": "yellow",
      "copyRule": "Explain potential paths and blockers without certainty."
    },
    "prepFirst": {
      "range": "0-44",
      "color": "red",
      "copyRule": "Route to education and document prep without shaming the user."
    }
  }
}
