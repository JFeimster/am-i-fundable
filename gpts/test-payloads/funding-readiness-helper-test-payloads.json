{
  "package": "Funding Readiness Helper",
  "server": "https://am-i-fundable.vercel.app",
  "auth": "none",
  "payloads": {
    "submitScorecard_workingCapital": {
      "method": "POST",
      "path": "/api/scorecard/submit-score",
      "body": {
        "source": "Funding Readiness Helper GPT",
        "applicant": {
          "businessName": "Demo Business LLC",
          "state": "DC"
        },
        "answers": {
          "businessPersona": "local_service_business",
          "monthlyRevenue": 25000,
          "timeInBusinessMonths": 18,
          "creditScore": 665,
          "bankStatus": "consistent",
          "businessStructure": "entity_with_bank",
          "fundingPurpose": "working_capital",
          "desiredFundingAmount": 50000,
          "redFlags": ["none"]
        }
      },
      "expectedBoundary": [
        "readiness score",
        "tier",
        "public funding family",
        "strengths/risks",
        "next steps",
        "not an approval disclaimer"
      ]
    },
    "requestFundingReview_standard": {
      "method": "POST",
      "path": "/api/scorecard/request-review",
      "body": {
        "source": "Funding Readiness Helper GPT",
        "requestedReviewType": "funding_path_review",
        "applicant": {
          "firstName": "Demo",
          "lastName": "Owner",
          "businessName": "Demo Business LLC",
          "email": "demo@example.com",
          "phone": "5555555555",
          "state": "DC",
          "consent": true
        },
        "answers": {
          "businessPersona": "local_service_business",
          "monthlyRevenue": 25000,
          "timeInBusinessMonths": 18,
          "creditScore": 665,
          "bankStatus": "consistent",
          "businessStructure": "entity_with_bank",
          "fundingPurpose": "working_capital",
          "desiredFundingAmount": 50000,
          "redFlags": ["none"]
        },
        "notes": "User requested human review after scorecard interpretation. Demo payload only."
      },
      "expectedBoundary": [
        "review status",
        "review id or receipt",
        "public-safe score result if returned",
        "next step",
        "not an approval disclaimer"
      ]
    },
    "recommendResources_reviewReady": {
      "method": "POST",
      "path": "/api/public/resource-recommendations",
      "body": {
        "tierId": "fundable_review",
        "fundingPurpose": "working_capital",
        "manualReviewRecommended": true
      },
      "expectedBoundary": [
        "educational resources",
        "public paths",
        "no private provider data"
      ]
    },
    "getDocumentChecklist_workingCapital": {
      "method": "GET",
      "path": "/api/public/document-checklist?fundingPurpose=working_capital",
      "expectedBoundary": [
        "document labels",
        "prep guidance",
        "next step",
        "no request for sensitive documents in chat"
      ]
    },
    "getPublicSiteData_faq": {
      "method": "GET",
      "path": "/api/public/site-data?dataset=faq",
      "expectedBoundary": [
        "public-safe FAQ content",
        "site copy only",
        "no private routing"
      ]
    },
    "error_missingConsent_review": {
      "method": "POST",
      "path": "/api/scorecard/request-review",
      "body": {
        "source": "Funding Readiness Helper GPT",
        "requestedReviewType": "funding_path_review",
        "applicant": {
          "firstName": "Demo",
          "lastName": "Owner",
          "businessName": "Demo Business LLC",
          "email": "demo@example.com",
          "state": "DC",
          "consent": false
        },
        "answers": {
          "businessPersona": "local_service_business",
          "monthlyRevenue": 25000,
          "timeInBusinessMonths": 18,
          "creditScore": 665,
          "bankStatus": "consistent",
          "businessStructure": "entity_with_bank",
          "fundingPurpose": "working_capital",
          "desiredFundingAmount": 50000,
          "redFlags": ["none"]
        }
      },
      "expectedBoundary": [
        "safe validation error",
        "ask for affirmative consent before review request",
        "no shame, no workaround"
      ]
    },
    "error_restrictedSensitiveData": {
      "description": "Do not send this to production as a positive test. Use only to verify GPT refusal behavior before action call.",
      "blockedUserInputExamples": [
        "Here is my SSN: 123-45-6789",
        "Here is my bank login password",
        "Here is my routing and account number"
      ],
      "expectedAssistantBehavior": [
        "Do not call an action",
        "Tell the user not to paste sensitive information",
        "Ask for safe summary fields instead"
      ]
    }
  }
}
