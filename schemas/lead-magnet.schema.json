{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://am-i-fundable.local/schemas/lead-magnet.schema.json",
  "title": "Lead Magnet",
  "description": "Validates public downloadable asset and lead magnet registry entries.",
  "type": "object",
  "required": [
    "id",
    "visibility",
    "lead_magnets"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public_runtime_browser_safe",
        "public_build_time_only"
      ]
    },
    "lead_magnets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "asset_type",
          "audience",
          "delivery_path",
          "gate_type",
          "safe_disclaimer"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "not": {
              "anyOf": [
                {
                  "pattern": "(?i)guaranteed funding"
                },
                {
                  "pattern": "(?i)instant approval"
                },
                {
                  "pattern": "(?i)final eligibility"
                },
                {
                  "pattern": "(?i)best rates"
                },
                {
                  "pattern": "(?i)approved"
                },
                {
                  "pattern": "(?i)approval guaranteed"
                }
              ]
            }
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "not": {
              "anyOf": [
                {
                  "pattern": "(?i)guaranteed funding"
                },
                {
                  "pattern": "(?i)instant approval"
                },
                {
                  "pattern": "(?i)final eligibility"
                },
                {
                  "pattern": "(?i)best rates"
                },
                {
                  "pattern": "(?i)approved"
                },
                {
                  "pattern": "(?i)approval guaranteed"
                }
              ]
            }
          },
          "asset_type": {
            "type": "string",
            "enum": [
              "checklist",
              "guide",
              "template",
              "calculator",
              "worksheet",
              "email_sequence",
              "report_sample"
            ]
          },
          "audience": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "delivery_path": {
            "type": "string",
            "pattern": "^\\/[a-z0-9][a-z0-9\\-/]*\\.?(html|json|md|xml|txt)?(#[-a-z0-9_]+)?$"
          },
          "gate_type": {
            "type": "string",
            "enum": [
              "ungated",
              "email_required",
              "review_request",
              "partner_access"
            ]
          },
          "related_page_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "safe_disclaimer": {
            "type": "string",
            "minLength": 1,
            "description": "Public-safe disclaimer language; must avoid approval or guarantee claims.",
            "not": {
              "pattern": "(?i)(guaranteed|instant approval|approved lender|best rate)"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
