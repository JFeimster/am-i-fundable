{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://am-i-fundable.vercel.app/schemas/funding-readiness-lead.schema.json",
  "title": "Canonical Funding Readiness Lead",
  "description": "Canonical cross-repository contract for funding-readiness evaluation, public-safe funding-family guidance, partner attribution, human review, persistence, dashboard sync, and GPT/action follow-up. This is not an approval, offer, underwriting decision, or lender-specific match.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lead_id",
    "applicant",
    "answers",
    "score_result",
    "lead_priority",
    "primary_funding_family",
    "secondary_funding_families",
    "risks",
    "strengths",
    "recommended_documents",
    "next_steps",
    "manual_review_recommended",
    "partner_id",
    "tracking_link_id",
    "campaign_id",
    "widget_id",
    "source_url",
    "source_asset",
    "utm_source",
    "utm_medium",
    "utm_campaign",
    "utm_term",
    "utm_content",
    "consent",
    "review_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "default": "1.0.0",
      "x-visibility": "public_response_safe"
    },
    "lead_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120,
      "pattern": "^lead_[A-Za-z0-9_-]+$",
      "x-visibility": "public_response_safe"
    },
    "applicant": {
      "$ref": "#/$defs/applicant",
      "x-visibility": "server_side_pii"
    },
    "answers": {
      "$ref": "#/$defs/answers",
      "x-visibility": "server_side_user_submitted"
    },
    "score_result": {
      "$ref": "#/$defs/scoreResult",
      "x-visibility": "public_response_safe"
    },
    "lead_priority": {
      "type": "string",
      "enum": ["hot", "warm", "nurture", "education", "manual_review"],
      "x-visibility": "server_side_and_operator"
    },
    "primary_funding_family": {
      "$ref": "#/$defs/fundingFamily",
      "x-visibility": "public_response_safe"
    },
    "secondary_funding_families": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/fundingFamily"
      },
      "x-visibility": "public_response_safe"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      },
      "x-visibility": "public_response_safe"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      },
      "x-visibility": "public_response_safe"
    },
    "recommended_documents": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "$ref": "#/$defs/documentItem"
      },
      "x-visibility": "public_response_safe"
    },
    "next_steps": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/nextStep"
      },
      "x-visibility": "public_response_safe"
    },
    "manual_review_recommended": {
      "type": "boolean",
      "x-visibility": "public_response_safe"
    },
    "partner_id": {
      "type": ["string", "null"],
      "minLength": 3,
      "maxLength": 120,
      "description": "Validated partner identifier. Null for direct traffic or unresolved attribution.",
      "x-visibility": "operator_and_partner_status_safe"
    },
    "tracking_link_id": {
      "type": ["string", "null"],
      "minLength": 3,
      "maxLength": 120,
      "description": "Validated tracking-link identifier associated with partner_id.",
      "x-visibility": "operator_and_partner_status_safe"
    },
    "campaign_id": {
      "type": ["string", "null"],
      "maxLength": 120,
      "x-visibility": "operator_and_partner_status_safe"
    },
    "widget_id": {
      "type": ["string", "null"],
      "maxLength": 120,
      "x-visibility": "operator_and_partner_status_safe"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048,
      "x-visibility": "server_side_and_operator"
    },
    "source_asset": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "description": "Stable source identifier such as am_i_fundable, fundstack_ai, wix_article, partner_widget, vertical_funnel, or gpt_action.",
      "x-visibility": "operator_and_analytics"
    },
    "utm_source": {
      "type": ["string", "null"],
      "maxLength": 200,
      "x-visibility": "operator_and_analytics"
    },
    "utm_medium": {
      "type": ["string", "null"],
      "maxLength": 200,
      "x-visibility": "operator_and_analytics"
    },
    "utm_campaign": {
      "type": ["string", "null"],
      "maxLength": 200,
      "x-visibility": "operator_and_analytics"
    },
    "utm_term": {
      "type": ["string", "null"],
      "maxLength": 200,
      "x-visibility": "operator_and_analytics"
    },
    "utm_content": {
      "type": ["string", "null"],
      "maxLength": 200,
      "x-visibility": "operator_and_analytics"
    },
    "consent": {
      "$ref": "#/$defs/consent",
      "x-visibility": "server_side_compliance"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "new",
        "scored",
        "queued_for_review",
        "awaiting_documents",
        "in_human_review",
        "reviewed",
        "nurture",
        "closed",
        "rejected_invalid"
      ],
      "x-visibility": "operator_and_partner_status_safe"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "x-visibility": "operator_and_partner_status_safe"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "x-visibility": "operator_and_partner_status_safe"
    },
    "internal_context": {
      "$ref": "#/$defs/internalContext",
      "x-visibility": "server_side_only"
    }
  },
  "$defs": {
    "applicant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_name", "last_name", "business_name", "email", "phone", "state"],
      "properties": {
        "first_name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "last_name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "business_name": { "type": "string", "minLength": 1, "maxLength": 180 },
        "email": { "type": "string", "format": "email", "maxLength": 254 },
        "phone": { "type": "string", "minLength": 7, "maxLength": 40 },
        "state": { "type": "string", "minLength": 2, "maxLength": 40 }
      }
    },
    "answers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_persona",
        "monthly_revenue",
        "time_in_business_months",
        "credit_score",
        "bank_status",
        "business_structure",
        "funding_purpose",
        "desired_funding_amount",
        "red_flags"
      ],
      "properties": {
        "business_persona": { "type": "string", "minLength": 1, "maxLength": 120 },
        "monthly_revenue": { "type": "number", "minimum": 0 },
        "time_in_business_months": { "type": "integer", "minimum": 0, "maximum": 1200 },
        "credit_score": { "type": "integer", "minimum": 0, "maximum": 850 },
        "bank_status": {
          "type": "string",
          "enum": ["none", "low_inconsistent", "consistent", "strong_clean", "recent_nsfs"]
        },
        "business_structure": {
          "type": "string",
          "enum": ["none", "sole_prop", "entity_no_bank", "entity_with_bank", "entity_bank_ein_clean"]
        },
        "funding_purpose": {
          "type": "string",
          "enum": [
            "working_capital",
            "inventory_materials",
            "growth_marketing",
            "equipment_vehicle",
            "real_estate",
            "ecommerce_growth",
            "startup_launch",
            "debt_refi",
            "business_credit",
            "not_sure"
          ]
        },
        "desired_funding_amount": { "type": "number", "minimum": 0 },
        "red_flags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "none",
              "open_bankruptcy",
              "tax_lien",
              "recent_missed_payments",
              "recent_nsfs",
              "new_bank_account",
              "existing_daily_advance",
              "marketplace_suspended",
              "no_current_revenue"
            ]
          }
        }
      }
    },
    "scoreResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "tier", "calculated_at", "engine_version"],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "tier": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "label", "summary"],
          "properties": {
            "id": {
              "type": "string",
              "enum": ["highly_fundable", "fundable_review", "selective_programs", "not_ready_fixable"]
            },
            "label": { "type": "string", "minLength": 1, "maxLength": 160 },
            "summary": { "type": "string", "minLength": 1, "maxLength": 800 }
          }
        },
        "calculated_at": { "type": "string", "format": "date-time" },
        "engine_version": { "type": "string", "minLength": 1, "maxLength": 40 }
      }
    },
    "fundingFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 2, "maxLength": 120 },
        "label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 800 },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "documentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "required"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "label": { "type": "string", "minLength": 1, "maxLength": 240 },
        "detail": { "type": ["string", "null"], "maxLength": 800 },
        "required": { "type": "boolean" }
      }
    },
    "nextStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "owner", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "label": { "type": "string", "minLength": 1, "maxLength": 300 },
        "owner": { "type": "string", "enum": ["applicant", "operator", "partner", "system"] },
        "status": { "type": "string", "enum": ["recommended", "queued", "in_progress", "completed", "skipped"] }
      }
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contact", "privacy", "captured_at", "method", "text_version"],
      "properties": {
        "contact": { "type": "boolean" },
        "privacy": { "type": "boolean" },
        "captured_at": { "type": "string", "format": "date-time" },
        "method": { "type": "string", "enum": ["web_form", "widget", "gpt_action", "operator_entry", "api"] },
        "text_version": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "internalContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attribution_status": {
          "type": "string",
          "enum": ["direct", "unresolved", "validated", "rejected"]
        },
        "raw_attribution_hints": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
        },
        "crm_record_ids": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "persistence_targets": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["notion", "google_sheets", "crm", "event_log"] }
        },
        "provider_match_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "internal_notes": { "type": "string", "maxLength": 5000 },
        "idempotency_key": { "type": "string", "maxLength": 200 },
        "correlation_id": { "type": "string", "maxLength": 200 }
      }
    }
  }
}
