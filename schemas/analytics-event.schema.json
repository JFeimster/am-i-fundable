{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://am-i-fundable.local/schemas/analytics-event.schema.json",
  "title": "Analytics Event",
  "description": "Validates public-safe analytics event taxonomy. Events must not contain borrower PII or private provider data.",
  "type": "object",
  "required": [
    "id",
    "visibility",
    "events"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public_runtime_browser_safe",
        "public_build_time_only"
      ]
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "trigger",
          "category",
          "allowed_properties"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "name": {
            "type": "string",
            "pattern": "^[a-z]+(_[a-z0-9]+)*$"
          },
          "trigger": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "navigation",
              "scorecard",
              "lead_capture",
              "result",
              "resource",
              "partner",
              "embed",
              "error"
            ]
          },
          "allowed_properties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "type",
                "privacy_level"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "string",
                    "number",
                    "integer",
                    "boolean"
                  ]
                },
                "privacy_level": {
                  "type": "string",
                  "enum": [
                    "anonymous",
                    "derived_non_pii",
                    "page_context"
                  ]
                },
                "description": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "do_not_send": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "name",
              "email",
              "phone",
              "provider_id",
              "affiliate_url",
              "apply_url"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
