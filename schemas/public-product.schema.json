{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://am-i-fundable.vercel.app/schemas/public-product.schema.json",
  "title": "Public Product",
  "description": "Public-safe product/tool card schema for browser-safe or build-time registries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "slug",
    "description",
    "visibilityClass"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "persona": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": [
        "idea",
        "draft",
        "active",
        "experimental",
        "archived"
      ]
    },
    "visibilityClass": {
      "type": "string",
      "enum": [
        "public_runtime_browser_safe",
        "public_build_time_only",
        "server_side_internal",
        "restricted_internal_no_repo"
      ]
    },
    "url": {
      "type": "string"
    },
    "ctaLabel": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
