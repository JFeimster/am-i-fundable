{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://distilledfunding.local/schemas/webhook-event.schema.json",
  "title": "Webhook Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event_id",
    "event_type",
    "source",
    "created_at",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "scorecard.submitted",
        "scorecard.matched",
        "scorecard.review_queued",
        "scorecard.error"
      ]
    },
    "source": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  }
}
