{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://am-i-fundable.local/schemas/resource.schema.json",
  "title": "Resource Library",
  "description": "Validates public resource-library entries for guides, checklists, FAQs, and tools.",
  "type": "object",
  "required": [
    "id",
    "visibility",
    "resources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public_runtime_browser_safe",
        "public_build_time_only"
      ]
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "resource_type",
          "href",
          "audience"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "not": {
              "anyOf": [
                {
                  "pattern": "(?i)guaranteed funding"
                },
                {
                  "pattern": "(?i)instant approval"
                },
                {
                  "pattern": "(?i)final eligibility"
                },
                {
                  "pattern": "(?i)best rates"
                },
                {
                  "pattern": "(?i)approved"
                },
                {
                  "pattern": "(?i)approval guaranteed"
                }
              ]
            }
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "not": {
              "anyOf": [
                {
                  "pattern": "(?i)guaranteed funding"
                },
                {
                  "pattern": "(?i)instant approval"
                },
                {
                  "pattern": "(?i)final eligibility"
                },
                {
                  "pattern": "(?i)best rates"
                },
                {
                  "pattern": "(?i)approved"
                },
                {
                  "pattern": "(?i)approval guaranteed"
                }
              ]
            }
          },
          "resource_type": {
            "type": "string",
            "enum": [
              "page",
              "checklist",
              "faq",
              "guide",
              "tool",
              "template",
              "demo",
              "legal"
            ]
          },
          "href": {
            "type": "string",
            "pattern": "^\\/[a-z0-9][a-z0-9\\-/]*\\.?(html|json|md|xml|txt)?(#[-a-z0-9_]+)?$"
          },
          "audience": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "featured": {
            "type": "boolean",
            "default": false
          },
          "sort_order": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
