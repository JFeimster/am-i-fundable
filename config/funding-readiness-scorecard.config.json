  "tiers": [
    {
      "id": "highly_fundable",
      "min": 80,
      "max": 100,
      "label": "Highly Fundable",
      "leadPriority": "hot",
      "summary": "Your answers suggest stronger readiness signals. A funding strategy review is the recommended next step."
    },
    {
      "id": "fundable_review",
      "min": 65,
      "max": 79,
      "label": "Fundable, But Needs Review",
      "leadPriority": "warm",
      "summary": "Your answers show several positive signals, with a few items that should be reviewed before applying."
