{
  "id": "funding-readiness-registry-manifest",
  "version": "1.0.0",
  "project": "funding-readiness-scorecard",
  "registries": [
    {
      "id": "compliance-copy",
      "file": "/data/compliance-copy.public.json",
      "visibility": "public_runtime_browser_safe",
      "purpose": "Disclaimers, consent copy, safe labels, and result language rules."
    },
    {
      "id": "registry-visibility",
      "file": "/config/registry-visibility.json",
      "visibility": "public_build_time_only",
      "purpose": "Visibility classes and public/internal data boundaries."
    },
    {
      "id": "scorecard-config",
      "file": "/config/funding-readiness-scorecard.config.json",
      "visibility": "public_runtime_browser_safe",
      "purpose": "Shared score weights, tiers, questions, and public labels."
    },
    {
      "id": "page-config",
      "file": "/config/pages/funding-readiness-scorecard.page.json",
      "visibility": "public_build_time_only",
      "purpose": "Landing page metadata, route references, and safe asset mapping."
    },
    {
      "id": "page-registry",
      "file": "/config/pages/funding-pages.registry.json",
      "visibility": "public_build_time_only",
      "purpose": "Registry of public page surfaces for the scorecard tool."
    },
    {
      "id": "route-registry",
      "file": "/config/routes.json",
      "visibility": "public_build_time_only",
      "purpose": "Public-safe route map for the landing page, widget, embed example, and API endpoints."
    },
    {
      "id": "asset-registry",
      "file": "/config/assets.json",
      "visibility": "public_build_time_only",
      "purpose": "Public-safe asset references used by the scorecard surfaces."
    },
    {
      "id": "tool-registry",
      "file": "/config/tool-registry.json",
      "visibility": "public_build_time_only",
      "purpose": "Reusable tool entrypoint and safety registry."
    },
    {
      "id": "control-registry",
      "file": "/config/control/funding-readiness.control.json",
      "visibility": "public_build_time_only",
      "purpose": "Deployment and feature flags for the scorecard tool."
    },
    {
      "id": "funnel-registry",
      "file": "/config/funnels/funding-readiness-scorecard.json",
      "visibility": "public_build_time_only",
      "purpose": "Conversion funnel for score calculation, lead capture, and review routing."
    },
    {
      "id": "brand-registry",
      "file": "/config/brands/moonshine-capital.json",
      "visibility": "public_build_time_only",
      "purpose": "Public brand voice and safe presentation guidance."
    },
    {
      "id": "lead-scoring-model",
      "file": "/internal/scoring/lead-scoring-model.registry.json",
      "visibility": "server_side_internal",
      "purpose": "Internal lead scoring rules and CRM priority model."
    },
    {
      "id": "borrower-qualification-stack",
      "file": "/config/borrower-qualification-stack.registry.json",
      "visibility": "public_build_time_only",
      "purpose": "Capture, score, reason, and route blueprint."
    },
    {
      "id": "scorecard-data-contract",
      "file": "/schemas/scorecard-data-contract.schema.json",
      "visibility": "public_build_time_only",
      "purpose": "Shared data contract for widget, landing page, API, and GPT actions."
    }
  ],
  "requiredPublicFiles": [
    "/data/compliance-copy.public.json",
    "/config/funding-readiness-scorecard.config.json",
    "/config/pages/funding-readiness-scorecard.page.json",
    "/config/routes.json",
    "/config/assets.json",
    "/config/tool-registry.json"
  ],
  "requiredInternalFiles": [
    "/internal/scoring/lead-scoring-model.registry.json"
  ]
}
