{
  "id": "review-request-form-config",
  "visibility": "public_runtime_browser_safe",
  "form_name": "Human Funding Readiness Review Request",
  "route": "/fundable-review.html",
  "purpose": "Collect enough context for a human to review readiness and recommend a next step without implying a funding decision.",
  "fields": [
    {
      "id": "name",
      "label": "Name",
      "type": "text",
      "required": true,
      "autocomplete": "name"
    },
    {
      "id": "email",
      "label": "Email",
      "type": "email",
      "required": true,
      "autocomplete": "email"
    },
    {
      "id": "phone",
      "label": "Phone",
      "type": "tel",
      "required": true,
      "autocomplete": "tel"
    },
    {
      "id": "business_name",
      "label": "Business name",
      "type": "text",
      "required": false,
      "autocomplete": "organization"
    },
    {
      "id": "state",
      "label": "Business state",
      "type": "text",
      "required": false,
      "maxlength": 30
    },
    {
      "id": "monthly_revenue_range",
      "label": "Monthly revenue range",
      "type": "select",
      "required": false,
      "options": [
        "$0–$2,999",
        "$3,000–$8,499",
        "$8,500–$14,999",
        "$15,000–$49,999",
        "$50,000+",
        "Not sure"
      ]
    },
    {
      "id": "funding_purpose",
      "label": "Funding purpose",
      "type": "select",
      "required": false,
      "options": [
        "Working capital",
        "Inventory/materials",
        "Equipment/vehicle",
        "Real estate",
        "Ecommerce growth",
        "Startup launch",
        "Business credit setup",
        "Not sure"
      ]
    },
    {
      "id": "requested_amount_range",
      "label": "Requested amount range",
      "type": "select",
      "required": false,
      "options": [
        "Under $5,000",
        "$5,000–$25,000",
        "$25,000–$75,000",
        "$75,000–$150,000",
        "$150,000+",
        "Not sure"
      ]
    },
    {
      "id": "score_range",
      "label": "Funding readiness score range",
      "type": "select",
      "required": false,
      "options": [
        "80–100",
        "65–79",
        "45–64",
        "0–44",
        "I have not taken the scorecard yet"
      ]
    },
    {
      "id": "notes",
      "label": "What should the reviewer know?",
      "type": "textarea",
      "required": false,
      "maxlength": 1000
    }
  ],
  "consent": {
    "required": true,
    "label": "I understand this request is for review only and is not an approval, offer, or guarantee of funding."
  },
  "success_state": {
    "route": "/thank-you.html",
    "heading": "Review request received",
    "message": "A human review is the next step when the scorecard suggests a closer look may be useful."
  },
  "routing_note": "Actual CRM routing belongs in internal/server-side files only. Do not add provider names, affiliate links, apply links, commission data, or private contacts here."
}
